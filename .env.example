# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Processing strategy:
#   enhance  - dynamics/EQ/denoise that lifts quiet background speech and tames the
#              loud foreground. Best for "people talking behind a wall" recordings.
#   separate - Demucs voice-vs-instruments separation. Best for music/songs where you
#              want to suppress the singer and keep the instrumental background.
PROCESSING_MODE=enhance

# Reject files larger than this (megabytes) to keep processing time sane.
MAX_FILE_SIZE_MB=20

# --- enhance mode tuning ---------------------------------------------------
# High-pass cutoff (Hz) to strip low-frequency rumble.
HIGHPASS_HZ=100
# Level (dBFS) above which the loud foreground starts getting compressed.
COMPRESSOR_THRESHOLD_DB=-35
# Compression ratio: higher squashes the loud foreground more vs the quiet background.
COMPRESSOR_RATIO=50
# Output gain (dB) applied after compression.
MAKEUP_GAIN_DB=6
# Max boost the dynamic normalizer may apply to quiet passages (1 = off).
DYNAUDNORM_MAX_GAIN=30
# Spectral noise-reduction strength in dB (0 disables it).
NOISE_REDUCTION_DB=6

# --- separate mode tuning (Demucs) -----------------------------------------
# Attenuate the voice stem, in decibels (negative = quieter).
VOCAL_GAIN_DB=-12
# Amplify the rest, in decibels (positive = louder).
BACKGROUND_GAIN_DB=8
# Demucs model name.
DEMUCS_MODEL=htdemucs
# Compute device: "auto", "cpu" or "cuda".
DEVICE=auto
