# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# How much to attenuate the dominant foreground voice, in decibels (negative = quieter).
VOCAL_GAIN_DB=-12

# How much to amplify the background, in decibels (positive = louder).
BACKGROUND_GAIN_DB=8

# Demucs model name. "htdemucs" is the default high-quality hybrid transformer model.
DEMUCS_MODEL=htdemucs

# Compute device: "auto", "cpu" or "cuda".
DEVICE=auto

# Reject files larger than this (megabytes) to keep processing time sane.
MAX_FILE_SIZE_MB=20
