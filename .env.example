# Telegram bot token from @BotFather (обязательно).
BOT_TOKEN=123456:ABC-your-token-here

MAX_FILE_SIZE_MB=20

# --- enhance: тихий передний голос, громкий задний фон ---------------------
# Срез гула (Гц). 100–200 обычно достаточно.
HIGHPASS_HZ=150
# Порог компрессора (дБ): ниже = раньше приглушается громкий голос. Минимум -60 (лимит ffmpeg).
COMPRESSOR_THRESHOLD_DB=-45
# Степень сжатия: выше = сильнее давит передний голос (12–20).
COMPRESSOR_RATIO=18
# Итоговая громкость после обработки (дБ).
MAKEUP_GAIN_DB=10
# Подъём тихих участков — главный рычаг для заднего фона (20–40).
DYNAUDNORM_MAX_GAIN=35
# Шумоподавление (дБ). Меньше = фон слышнее, больше = меньше шипения.
NOISE_REDUCTION_DB=4

# --- separate: Demucs + нейро-постобработка --------------------------------
VOCAL_GAIN_DB=-12
BACKGROUND_GAIN_DB=8
DEMUCS_MODEL=htdemucs
DEVICE=auto
# non_vocal = drums+bass+other; other = только стем «прочее»
BACKGROUND_STEMS=non_vocal
# auto | deepfilternet | rnnoise | off
SPEECH_ENHANCER=auto
# de-clip + лёгкий de-reverb через ffmpeg (adeclip + afftdn)
RESTORATION_ENABLED=true

# --- ASR: Whisper (faster-whisper) -----------------------------------------
WHISPER_ENABLED=true
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
